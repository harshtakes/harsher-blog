import Header from '../components/Header.astro';
import '../styles/global.css';

const { title, description, pubDate } = Astro.props;

function formatDate(date) {
  return new Date(date).toLocaleDateString('en-IN', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
