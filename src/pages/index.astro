<script>
// ── TIME-BASED COLOR THEME ──
(function(){
  const h = new Date().getHours();
  const root = document.documentElement;
  if (h >= 5 && h < 8) {
    root.style.setProperty('--bg','#050308');
    root.style.setProperty('--purple','#f59e0b');
    root.style.setProperty('--cyan','#fb923c');
  } else if (h >= 20 || h < 5) {
    root.style.setProperty('--bg','#020408');
  } else {
    root.style.setProperty('--bg','#020610');
  }
})();

// ── CURSOR ──
const cursor = document.getElementById('cursor');
let mx = -200, my = -200;
document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cursor.style.left = mx + 'px';
  cursor.style.top = my + 'px';
});

// ── THREE.JS NEURAL SPHERE ──
const threeCanvas = document.getElementById('three-canvas');
const renderer = new THREE.WebGLRenderer({ canvas: threeCanvas, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setClearColor(0x000000, 0);

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
camera.position.z = 5;

// Sphere points
const sphereGeo = new THREE.SphereGeometry(2.2, 32, 32);
const pointsMat = new THREE.PointsMaterial({ color: 0xa855f7, size: 0.025, transparent: true, opacity: 0.6 });
const spherePoints = new THREE.Points(sphereGeo, pointsMat);
scene.add(spherePoints);

// Wireframe sphere
const wireMat = new THREE.MeshBasicMaterial({ color: 0x06b6d4, wireframe: true, transparent: true, opacity: 0.06 });
const wireMesh = new THREE.Mesh(sphereGeo, wireMat);
scene.add(wireMesh);

// Inner glowing sphere
const innerGeo = new THREE.SphereGeometry(1.1, 16, 16);
const innerMat = new THREE.MeshBasicMaterial({ color: 0x7c3aed, wireframe: true, transparent: true, opacity: 0.08 });
const innerMesh = new THREE.Mesh(innerGeo, innerMat);
scene.add(innerMesh);

// Floating connection lines between random sphere surface points
const positions = sphereGeo.attributes.position;
const lineGroup = new THREE.Group();
for (let i = 0; i < 60; i++) {
  const idxA = Math.floor(Math.random() * positions.count);
  const idxB = Math.floor(Math.random() * positions.count);
  const ax = positions.getX(idxA) * 1.01, ay = positions.getY(idxA) * 1.01, az = positions.getZ(idxA) * 1.01;
  const bx = positions.getX(idxB) * 1.01, by = positions.getY(idxB) * 1.01, bz = positions.getZ(idxB) * 1.01;
  const dist = Math.sqrt((bx-ax)**2+(by-ay)**2+(bz-az)**2);
  if (dist > 1.8) continue;
  const pts = [new THREE.Vector3(ax,ay,az), new THREE.Vector3(bx,by,bz)];
  const geo = new THREE.BufferGeometry().setFromPoints(pts);
  const mat = new THREE.LineBasicMaterial({ color: 0x06b6d4, transparent: true, opacity: 0.15 });
  lineGroup.add(new THREE.Line(geo, mat));
}
scene.add(lineGroup);

// Orbiting particles
const orbCount = 120;
const orbGeo = new THREE.BufferGeometry();
const orbPos = new Float32Array(orbCount * 3);
const orbAngles = [];
for (let i = 0; i < orbCount; i++) {
  const theta = Math.random() * Math.PI * 2;
  const phi = Math.acos(2 * Math.random() - 1);
  const r = 2.5 + Math.random() * 1.5;
  orbAngles.push({ theta, phi, r, speed: (Math.random() - 0.5) * 0.003 });
  orbPos[i*3] = r * Math.sin(phi) * Math.cos(theta);
  orbPos[i*3+1] = r * Math.sin(phi) * Math.sin(theta);
  orbPos[i*3+2] = r * Math.cos(phi);
}
orbGeo.setAttribute('position', new THREE.BufferAttribute(orbPos, 3));
const orbMat = new THREE.PointsMaterial({ color: 0x10b981, size: 0.04, transparent: true, opacity: 0.5 });
const orbPoints = new THREE.Points(orbGeo, orbMat);
scene.add(orbPoints);

// Mouse influence on sphere
let targetRotX = 0, targetRotY = 0;
document.addEventListener('mousemove', e => {
  targetRotY = (e.clientX / window.innerWidth - 0.5) * 0.8;
  targetRotX = (e.clientY / window.innerHeight - 0.5) * 0.5;
});

let frameCount = 0, lastFPSTime = 0, fps = 0;

function animateThree(ts) {
  requestAnimationFrame(animateThree);
  frameCount++;
  if (ts - lastFPSTime >= 1000) {
    fps = frameCount;
    frameCount = 0;
    lastFPSTime = ts;
    const el = document.getElementById('h-fps');
    if (el) el.textContent = fps;
  }
  const t = ts * 0.001;
  spherePoints.rotation.y += 0.0015;
  spherePoints.rotation.x += 0.0008;
  wireMesh.rotation.y += 0.001;
  wireMesh.rotation.x -= 0.0005;
  innerMesh.rotation.y -= 0.002;
  innerMesh.rotation.z += 0.001;
  lineGroup.rotation.y = spherePoints.rotation.y;
  lineGroup.rotation.x = spherePoints.rotation.x;

  // Mouse gravity
  spherePoints.rotation.y += (targetRotY - spherePoints.rotation.y) * 0.02;
  spherePoints.rotation.x += (targetRotX - spherePoints.rotation.x) * 0.02;

  // Orbiting particles
  const op = orbGeo.attributes.position.array;
  for (let i = 0; i < orbCount; i++) {
    orbAngles[i].theta += orbAngles[i].speed;
    const { theta, phi, r } = orbAngles[i];
    op[i*3] = r * Math.sin(phi) * Math.cos(theta);
    op[i*3+1] = r * Math.sin(phi) * Math.sin(theta) + Math.sin(t * 0.3 + i) * 0.05;
    op[i*3+2] = r * Math.cos(phi);
  }
  orbGeo.attributes.position.needsUpdate = true;

  renderer.render(scene, camera);
}
animateThree(0);

// ── PARTICLE BURST ON LOAD ──
const pc = document.getElementById('particle-canvas');
const pctx = pc.getContext('2d');
let PW = pc.width = window.innerWidth, PH = pc.height = window.innerHeight;
const particles = [];
const COLS = ['#a855f7','#06b6d4','#10b981','#ec4899'];

for (let i = 0; i < 180; i++) {
  const angle = Math.random() * Math.PI * 2;
  const speed = Math.random() * 4 + 1;
  particles.push({
    x: PW/2, y: PH/2,
    vx: Math.cos(angle) * speed,
    vy: Math.sin(angle) * speed,
    life: 1, decay: Math.random() * 0.012 + 0.008,
    size: Math.random() * 3 + 0.5,
    color: COLS[Math.floor(Math.random() * COLS.length)],
    done: false,
  });
}

function drawParticles() {
  pctx.clearRect(0, 0, PW, PH);
  let anyAlive = false;
  particles.forEach(p => {
    if (p.done) return;
    p.x += p.vx; p.y += p.vy;
    p.vx *= 0.97; p.vy *= 0.97;
    p.vy += 0.04;
    p.life -= p.decay;
    if (p.life <= 0) { p.done = true; return; }
    anyAlive = true;
    pctx.beginPath();
    pctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
    pctx.fillStyle = p.color;
    pctx.globalAlpha = p.life * 0.8;
    pctx.fill();
    pctx.globalAlpha = 1;
  });
  if (anyAlive) requestAnimationFrame(drawParticles);
  else pctx.clearRect(0, 0, PW, PH);
}
drawParticles();

// ── DNA HELIX CURSOR TRAIL ──
const tc2 = document.getElementById('trail-canvas');
const tctx = tc2.getContext('2d');
let TW = tc2.width = window.innerWidth, TH = tc2.height = window.innerHeight;
const trailPoints = [];

document.addEventListener('mousemove', e => {
  trailPoints.push({ x: e.clientX, y: e.clientY, t: Date.now() });
  if (trailPoints.length > 80) trailPoints.shift();
});

function drawTrail() {
  tctx.clearRect(0, 0, TW, TH);
  for (let i = 1; i < trailPoints.length; i++) {
    const p = trailPoints[i];
    const age = (Date.now() - p.t) / 1000;
    if (age > 0.8) continue;
    const life = 1 - age / 0.8;
    const offset = Math.sin(i * 0.4 + Date.now() * 0.004) * 6 * life;
    // Strand A
    tctx.beginPath();
    tctx.arc(p.x + offset, p.y, 1.8 * life, 0, Math.PI * 2);
    tctx.fillStyle = `rgba(168,85,247,${life * 0.6})`;
    tctx.fill();
    // Strand B
    tctx.beginPath();
    tctx.arc(p.x - offset, p.y, 1.8 * life, 0, Math.PI * 2);
    tctx.fillStyle = `rgba(6,182,212,${life * 0.6})`;
    tctx.fill();
    // Bridge every 5 points
    if (i % 5 === 0) {
      tctx.beginPath();
      tctx.moveTo(p.x + offset, p.y);
      tctx.lineTo(p.x - offset, p.y);
      tctx.strokeStyle = `rgba(16,185,129,${life * 0.3})`;
      tctx.lineWidth = 0.8;
      tctx.stroke();
    }
  }
  requestAnimationFrame(drawTrail);
}
drawTrail();

// ── 3D CARD TILT ──
document.querySelectorAll('.post-card').forEach(card => {
  card.addEventListener('mousemove', e => {
    const rect = card.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + rect.height / 2;
    const dx = (e.clientX - cx) / (rect.width / 2);
    const dy = (e.clientY - cy) / (rect.height / 2);
    card.style.transform = `perspective(800px) rotateY(${dx * 4}deg) rotateX(${-dy * 3}deg) translateZ(4px)`;
    const glow = card.querySelector('.card-glow');
    const px = ((e.clientX - rect.left) / rect.width * 100).toFixed(1);
    const py = ((e.clientY - rect.top) / rect.height * 100).toFixed(1);
    if (glow) glow.style.setProperty('background', `radial-gradient(circle at ${px}% ${py}%, rgba(6,182,212,0.08), transparent 60%)`);
  });
  card.addEventListener('mouseleave', () => {
    card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg) translateZ(0)';
    card.style.transition = 'transform 0.4s ease, border-color 0.3s';
    setTimeout(() => { card.style.transition = ''; }, 400);
  });
});

// ── HUD UPDATES ──
function updateHUD() {
  const now = new Date();
  const p = n => String(n).padStart(2,'0');
  const el = id => document.getElementById(id);
  if (el('h-time')) el('h-time').textContent = `${p(now.getHours())}:${p(now.getMinutes())}:${p(now.getSeconds())}`;
  const mem = 38 + Math.round(Math.random() * 28);
  if (el('h-mem')) el('h-mem').textContent = mem;
  if (el('h-mem-bar')) el('h-mem-bar').style.width = mem + '%';
  if (el('h-net')) el('h-net').textContent = 6 + Math.floor(Math.random() * 14);
}
setInterval(updateHUD, 1000);
updateHUD();

// ── MULTILINGUAL HEADLINE ROTATION ──
const langs = [
  { code: 'EN', l1: 'LAW MEETS MACHINE.', l2: 'HARSH TAKES ONLY.' },
  { code: 'HI', l1: 'कानून मिलता है मशीन से.', l2: 'सिर्फ कड़े विचार.' },
  { code: 'JA', l1: '法律と機械の交差点.', l2: 'ハーシュの視点のみ.' },
  { code: 'AR', l1: 'القانون يلتقي بالآلة.', l2: 'آراء حادة فقط.' },
  { code: 'EN', l1: 'LAW MEETS MACHINE.', l2: 'HARSH TAKES ONLY.' },
];
const GLITCH_CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*';
let langIdx = 0;

function glitchText(el, target, cb) {
  let iter = 0;
  const orig = el.textContent;
  const maxLen = Math.max(orig.length, target.length);
  const iv = setInterval(() => {
    el.textContent = Array.from({ length: maxLen }, (_, i) => {
      if (i < iter) return target[i] || '';
      return target[i] ? GLITCH_CHARS[Math.floor(Math.random() * GLITCH_CHARS.length)] : '';
    }).join('');
    iter += 1.2;
    if (iter > maxLen) { el.textContent = target; clearInterval(iv); if (cb) cb(); }
  }, 35);
}

setInterval(() => {
  langIdx = (langIdx + 1) % langs.length;
  const l = langs[langIdx];
  const t1 = document.getElementById('title-1');
  const t2 = document.getElementById('title-2');
  const ll = document.getElementById('lang-label');
  if (ll) ll.textContent = `[ ${l.code} ]`;
  if (t1) glitchText(t1, l.l1, () => { if (t2) glitchText(t2, l.l2); });
}, 7000);

// ── INTERCEPTED TRANSMISSIONS ──
const txMessages = [
  'OpenAI sued for practicing law without a license in Illinois federal court.',
  'EU AI Act enforcement begins — 6 companies face compliance audits.',
  'ChatGPT cited in 847 court filings this quarter. Judges push back.',
  'India drafts Digital India Act — AI liability clauses under review.',
  'Supreme Court to hear first AI copyright case next term.',
  'NLU Mumbai hosts inaugural AI Law Symposium — 200 students attend.',
  'Google DeepMind releases legal reasoning model — bar exam: 94th percentile.',
  'Delhi High Court bars AI-generated evidence without human verification.',
];
let txIdx = 0;
const txEl = document.getElementById('transmission');
const txText = document.getElementById('tx-text');
const txClose = document.getElementById('tx-close');

function showTransmission() {
  if (!txEl || !txText) return;
  txText.textContent = txMessages[txIdx % txMessages.length];
  txIdx++;
  txEl.classList.add('show');
  setTimeout(() => txEl.classList.remove('show'), 6000);
}

if (txClose) txClose.addEventListener('click', () => txEl.classList.remove('show'));
setTimeout(showTransmission, 5000);
setInterval(showTransmission, 35000);

// ── RESIZE ──
window.addEventListener('resize', () => {
  renderer.setSize(window.innerWidth, window.innerHeight);
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  PW = pc.width = TW = tc2.width = window.innerWidth;
  PH = pc.height = TH = tc2.height = window.innerHeight;
});
</script>
