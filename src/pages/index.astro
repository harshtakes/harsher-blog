<script>
// THEME
const themeToggle = document.getElementById('themeToggle');
const savedTheme = localStorage.getItem('ht-theme') || 'dark';
document.documentElement.setAttribute('data-theme', savedTheme);
document.querySelectorAll('.tbtn').forEach(btn => {
  btn.classList.toggle('active', btn.dataset.mode === savedTheme);
  btn.addEventListener('click', () => {
    const mode = btn.dataset.mode;
    localStorage.setItem('ht-theme', mode);
    document.documentElement.setAttribute('data-theme', mode);
    document.querySelectorAll('.tbtn').forEach(b => b.classList.toggle('active', b.dataset.mode === mode));
  });
});

// CURSOR
const cursor = document.getElementById('cursor');
let mx=-200,my=-200;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});

// THREE.JS
const threeCanvas=document.getElementById('three-canvas');
const renderer=new THREE.WebGLRenderer({canvas:threeCanvas,antialias:true,alpha:true});
renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
renderer.setSize(window.innerWidth,window.innerHeight);
renderer.setClearColor(0x000000,0);
const scene=new THREE.Scene();
const camera=new THREE.PerspectiveCamera(60,window.innerWidth/window.innerHeight,0.1,1000);
camera.position.z=5;
const sphereGeo=new THREE.SphereGeometry(2.2,32,32);
const spherePoints=new THREE.Points(sphereGeo,new THREE.PointsMaterial({color:0xa855f7,size:0.025,transparent:true,opacity:0.6}));
scene.add(spherePoints);
const wireMesh=new THREE.Mesh(sphereGeo,new THREE.MeshBasicMaterial({color:0x06b6d4,wireframe:true,transparent:true,opacity:0.06}));
scene.add(wireMesh);
const innerMesh=new THREE.Mesh(new THREE.SphereGeometry(1.1,16,16),new THREE.MeshBasicMaterial({color:0x7c3aed,wireframe:true,transparent:true,opacity:0.08}));
scene.add(innerMesh);
const positions=sphereGeo.attributes.position;
const lineGroup=new THREE.Group();
for(let i=0;i<60;i++){
  const iA=Math.floor(Math.random()*positions.count),iB=Math.floor(Math.random()*positions.count);
  const ax=positions.getX(iA)*1.01,ay=positions.getY(iA)*1.01,az=positions.getZ(iA)*1.01;
  const bx=positions.getX(iB)*1.01,by=positions.getY(iB)*1.01,bz=positions.getZ(iB)*1.01;
  if(Math.sqrt((bx-ax)**2+(by-ay)**2+(bz-az)**2)>1.8)continue;
  const g=new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(ax,ay,az),new THREE.Vector3(bx,by,bz)]);
  lineGroup.add(new THREE.Line(g,new THREE.LineBasicMaterial({color:0x06b6d4,transparent:true,opacity:0.15})));
}
scene.add(lineGroup);
const orbCount=120,orbGeo=new THREE.BufferGeometry(),orbPos=new Float32Array(orbCount*3),orbAngles=[];
for(let i=0;i<orbCount;i++){
  const theta=Math.random()*Math.PI*2,phi=Math.acos(2*Math.random()-1),r=2.5+Math.random()*1.5;
  orbAngles.push({theta,phi,r,speed:(Math.random()-0.5)*0.003});
  orbPos[i*3]=r*Math.sin(phi)*Math.cos(theta);orbPos[i*3+1]=r*Math.sin(phi)*Math.sin(theta);orbPos[i*3+2]=r*Math.cos(phi);
}
orbGeo.setAttribute('position',new THREE.BufferAttribute(orbPos,3));
scene.add(new THREE.Points(orbGeo,new THREE.PointsMaterial({color:0x10b981,size:0.04,transparent:true,opacity:0.5})));
let tRX=0,tRY=0;
document.addEventListener('mousemove',e=>{tRY=(e.clientX/window.innerWidth-0.5)*0.8;tRX=(e.clientY/window.innerHeight-0.5)*0.5;});
let fc=0,lft=0,fpsv=0;
function animateThree(ts){
  requestAnimationFrame(animateThree);fc++;
  if(ts-lft>=1000){fpsv=fc;fc=0;lft=ts;const fe=document.getElementById('h-fps');if(fe)fe.textContent=fpsv;}
  const t=ts*0.001;
  spherePoints.rotation.y+=0.0015;spherePoints.rotation.x+=0.0008;
  wireMesh.rotation.y+=0.001;wireMesh.rotation.x-=0.0005;
  innerMesh.rotation.y-=0.002;innerMesh.rotation.z+=0.001;
  lineGroup.rotation.y=spherePoints.rotation.y;lineGroup.rotation.x=spherePoints.rotation.x;
  spherePoints.rotation.y+=(tRY-spherePoints.rotation.y)*0.02;
  spherePoints.rotation.x+=(tRX-spherePoints.rotation.x)*0.02;
  const op=orbGeo.attributes.position.array;
  for(let i=0;i<orbCount;i++){
    orbAngles[i].theta+=orbAngles[i].speed;
    const{theta,phi,r}=orbAngles[i];
    op[i*3]=r*Math.sin(phi)*Math.cos(theta);
    op[i*3+1]=r*Math.sin(phi)*Math.sin(theta)+Math.sin(t*0.3+i)*0.05;
    op[i*3+2]=r*Math.cos(phi);
  }
  orbGeo.attributes.position.needsUpdate=true;
  renderer.render(scene,camera);
}
animateThree(0);

// PARTICLES
const pc=document.getElementById('particle-canvas');
const pctx=pc.getContext('2d');
let PW=pc.width=window.innerWidth,PH=pc.height=window.innerHeight;
const COLS=['#a855f7','#06b6d4','#10b981','#ec4899'];
const particles=Array.from({length:180},()=>{
  const angle=Math.random()*Math.PI*2,speed=Math.random()*4+1;
  return{x:PW/2,y:PH/2,vx:Math.cos(angle)*speed,vy:Math.sin(angle)*speed,life:1,decay:Math.random()*0.012+0.008,size:Math.random()*3+0.5,color:COLS[Math.floor(Math.random()*COLS.length)],done:false};
});
function drawParticles(){
  pctx.clearRect(0,0,PW,PH);let alive=false;
  particles.forEach(p=>{
    if(p.done)return;p.x+=p.vx;p.y+=p.vy;p.vx*=0.97;p.vy*=0.97;p.vy+=0.04;p.life-=p.decay;
    if(p.life<=0){p.done=true;return;}alive=true;
    pctx.beginPath();pctx.arc(p.x,p.y,p.size*p.life,0,Math.PI*2);
    pctx.fillStyle=p.color;pctx.globalAlpha=p.life*0.8;pctx.fill();pctx.globalAlpha=1;
  });
  if(alive)requestAnimationFrame(drawParticles);else pctx.clearRect(0,0,PW,PH);
}
drawParticles();

// DNA TRAIL
const tc2=document.getElementById('trail-canvas');
const tctx=tc2.getContext('2d');
let TW=tc2.width=window.innerWidth,TH=tc2.height=window.innerHeight;
const trailPts=[];
document.addEventListener('mousemove',e=>{trailPts.push({x:e.clientX,y:e.clientY,t:Date.now()});if(trailPts.length>80)trailPts.shift();});
function drawTrail(){
  tctx.clearRect(0,0,TW,TH);
  for(let i=1;i<trailPts.length;i++){
    const p=trailPts[i],age=(Date.now()-p.t)/1000;
    if(age>0.8)continue;const life=1-age/0.8;
    const off=Math.sin(i*0.4+Date.now()*0.004)*6*life;
    tctx.beginPath();tctx.arc(p.x+off,p.y,1.8*life,0,Math.PI*2);tctx.fillStyle=`rgba(168,85,247,${life*0.6})`;tctx.fill();
    tctx.beginPath();tctx.arc(p.x-off,p.y,1.8*life,0,Math.PI*2);tctx.fillStyle=`rgba(6,182,212,${life*0.6})`;tctx.fill();
    if(i%5===0){tctx.beginPath();tctx.moveTo(p.x+off,p.y);tctx.lineTo(p.x-off,p.y);tctx.strokeStyle=`rgba(16,185,129,${life*0.3})`;tctx.lineWidth=0.8;tctx.stroke();}
  }
  requestAnimationFrame(drawTrail);
}
drawTrail();

// 3D CARD TILT
document.querySelectorAll('.post-card').forEach(card=>{
  card.addEventListener('mousemove',e=>{
    const r=card.getBoundingClientRect();
    const dx=(e.clientX-r.left-r.width/2)/(r.width/2),dy=(e.clientY-r.top-r.height/2)/(r.height/2);
    card.style.transform=`perspective(800px) rotateY(${dx*4}deg) rotateX(${-dy*3}deg) translateZ(4px)`;
    const glow=card.querySelector('.card-glow');
    if(glow)glow.style.background=`radial-gradient(circle at ${((e.clientX-r.left)/r.width*100).toFixed(1)}% ${((e.clientY-r.top)/r.height*100).toFixed(1)}%,rgba(6,182,212,0.08),transparent 60%)`;
  });
  card.addEventListener('mouseleave',()=>{
    card.style.transform='perspective(800px) rotateX(0) rotateY(0) translateZ(0)';
    card.style.transition='transform 0.4s ease,border-color 0.3s';
    setTimeout(()=>{card.style.transition='';},400);
  });
});

// HUD
function updateHUD(){
  const now=new Date(),p=n=>String(n).padStart(2,'0'),el=id=>document.getElementById(id);
  if(el('h-time'))el('h-time').textContent=`${p(now.getHours())}:${p(now.getMinutes())}:${p(now.getSeconds())}`;
  const mem=38+Math.round(Math.random()*28);
  if(el('h-mem'))el('h-mem').textContent=mem;
  if(el('h-mem-bar'))el('h-mem-bar').style.width=mem+'%';
  if(el('h-net'))el('h-net').textContent=6+Math.floor(Math.random()*14);
}
setInterval(updateHUD,1000);updateHUD();

// MULTILINGUAL
const langs=[
  {code:'EN',l1:'LAW MEETS MACHINE.',l2:'HARSH TAKES ONLY.'},
  {code:'HI',l1:'कानून मिलता है मशीन से.',l2:'सिर्फ़ कड़े विचार.'},
  {code:'JA',l1:'法律と機械の交差点.',l2:'ハーシュの視点のみ.'},
  {code:'AR',l1:'القانون يلتقي بالآلة.',l2:'آراء حادة فقط.'},
  {code:'EN',l1:'LAW MEETS MACHINE.',l2:'HARSH TAKES ONLY.'},
];
const GC='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*';
let langIdx=0;
function glitchText(el,target,cb){
  const isLatin=/^[A-Za-z0-9\s.,!?@#$%&*\-]+$/.test(target);
  if(!isLatin){el.textContent=target;if(cb)setTimeout(cb,100);return;}
  let iter=0;const maxLen=Math.max(el.textContent.length,target.length);
  const iv=setInterval(()=>{
    el.textContent=Array.from({length:maxLen},(_,i)=>i<iter?target[i]||'':(target[i]?GC[Math.floor(Math.random()*GC.length)]:'')).join('');
    iter+=1.2;if(iter>maxLen){el.textContent=target;clearInterval(iv);if(cb)cb();}
  },35);
}
setInterval(()=>{
  langIdx=(langIdx+1)%langs.length;const l=langs[langIdx];
  const t1=document.getElementById('title-1'),t2=document.getElementById('title-2'),ll=document.getElementById('lang-label');
  if(ll)ll.textContent=`[ ${l.code} ]`;
  if(t1)glitchText(t1,l.l1,()=>{if(t2)glitchText(t2,l.l2);});
},7000);

// TRANSMISSIONS
const txMsgs=['OpenAI sued for practicing law without a license in Illinois federal court.','EU AI Act enforcement begins — 6 companies face compliance audits.','ChatGPT cited in 847 court filings this quarter. Judges push back.','India drafts Digital India Act — AI liability clauses under review.','Supreme Court to hear first AI copyright case next term.','NLU Mumbai hosts inaugural AI Law Symposium — 200 students attend.','Google DeepMind releases legal reasoning model — bar exam: 94th percentile.','Delhi High Court bars AI-generated evidence without human verification.'];
let txIdx=0;
const txEl=document.getElementById('transmission'),txText=document.getElementById('tx-text'),txClose=document.getElementById('tx-close');
function showTx(){if(!txEl||!txText)return;txText.textContent=txMsgs[txIdx++%txMsgs.length];txEl.classList.add('show');setTimeout(()=>txEl.classList.remove('show'),6000);}
if(txClose)txClose.addEventListener('click',()=>txEl.classList.remove('show'));
setTimeout(showTx,5000);setInterval(showTx,35000);

// RESIZE
window.addEventListener('resize',()=>{
  renderer.setSize(window.innerWidth,window.innerHeight);
  camera.aspect=window.innerWidth/window.innerHeight;camera.updateProjectionMatrix();
  PW=pc.width=TW=tc2.width=window.innerWidth;PH=pc.height=TH=tc2.height=window.innerHeight;
});
</script>
