<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root {
  --bg:#020408;
  --purple:#a855f7;
  --cyan:#06b6d4;
  --green:#10b981;
  --pink:#ec4899;
  --amber:#f59e0b;
  --text:#f0eeff;
  --text2:#94a3b8;
  --text3:#cbd5e1;
  --border:rgba(168,85,247,0.12);
  --border-hover:rgba(6,182,212,0.35);
  --card:rgba(8,8,18,0.75);
  --canvas-op:0.7;
  --mono:'Share Tech Mono',monospace;
  --orb:'Orbitron',sans-serif;
  --sans:'Outfit',sans-serif;
}

[data-theme="light"] {
  --bg:#eef2ff;
  --purple:#7c3aed;
  --cyan:#0891b2;
  --green:#059669;
  --pink:#db2777;
  --text:#0f0a1e;
  --text2:#374151;
  --text3:#1f2937;
  --border:rgba(124,58,237,0.15);
  --border-hover:rgba(8,145,178,0.4);
  --card:rgba(255,255,255,0.88);
  --canvas-op:0.2;
}

@media(prefers-color-scheme:light){
  [data-theme="system"]{
    --bg:#eef2ff;--purple:#7c3aed;--cyan:#0891b2;--green:#059669;--pink:#db2777;
    --text:#0f0a1e;--text2:#374151;--text3:#1f2937;
    --border:rgba(124,58,237,0.15);--border-hover:rgba(8,145,178,0.4);
    --card:rgba(255,255,255,0.88);--canvas-op:0.2;
  }
}
@media(prefers-color-scheme:dark){
  [data-theme="system"]{
    --bg:#020408;--purple:#a855f7;--cyan:#06b6d4;--green:#10b981;--pink:#ec4899;
    --text:#f0eeff;--text2:#94a3b8;--text3:#cbd5e1;
    --border:rgba(168,85,247,0.12);--border-hover:rgba(6,182,212,0.35);
    --card:rgba(8,8,18,0.75);--canvas-op:0.7;
  }
}

html,body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;overflow-x:hidden;cursor:none;-webkit-font-smoothing:antialiased;transition:background 0.3s,color 0.3s;}

#three-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;opacity:var(--canvas-op);transition:opacity 0.4s;}
#trail-canvas,#particle-canvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;}
#trail-canvas{z-index:2}#particle-canvas{z-index:1}

.scanlines{position:fixed;inset:0;z-index:3;pointer-events:none;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.05) 3px,rgba(0,0,0,0.05) 4px);}
[data-theme="light"] .scanlines{display:none}
.grid-overlay{position:fixed;inset:0;z-index:3;pointer-events:none;background-image:linear-gradient(rgba(6,182,212,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(6,182,212,0.025) 1px,transparent 1px);background-size:55px 55px;}

#cursor{position:fixed;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);}
#cursor-outer{width:28px;height:28px;border:1px solid rgba(6,182,212,0.6);border-radius:50%;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);animation:cur-pulse 2s ease-in-out infinite;}
#cursor-inner{width:5px;height:5px;background:var(--cyan);border-radius:50%;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);box-shadow:0 0 8px var(--cyan);}
#cursor-h{position:absolute;top:50%;left:-8px;right:-8px;height:1px;background:rgba(6,182,212,0.5);transform:translateY(-50%);}
#cursor-v{position:absolute;left:50%;top:-8px;bottom:-8px;width:1px;background:rgba(6,182,212,0.5);transform:translateX(-50%);}
@keyframes cur-pulse{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:0.8}50%{transform:translate(-50%,-50%) scale(1.5);opacity:0.3}}

.hud{position:fixed;z-index:10;font-family:var(--mono);font-size:0.58rem;color:var(--cyan);pointer-events:none;line-height:2;letter-spacing:0.07em;opacity:0.65;}
.hud-tl{top:1rem;left:1rem}.hud-tr{top:1rem;right:1rem;text-align:right}.hud-bl{bottom:1rem;left:1rem}.hud-br{bottom:1rem;right:1rem;text-align:right}
.hv{color:var(--purple)}.hg{color:var(--green)}
.hud-bar{display:inline-block;width:50px;height:3px;background:rgba(168,85,247,0.2);vertical-align:middle;margin-left:4px;}
.hud-bar-fill{height:100%;background:linear-gradient(90deg,var(--purple),var(--cyan));transition:width 1.5s ease;}
.hud-bracket{position:fixed;z-index:10;pointer-events:none;opacity:0.3;}
.hud-bracket.tl{top:.4rem;left:.4rem}.hud-bracket.tr{top:.4rem;right:.4rem;transform:scaleX(-1)}
.hud-bracket.bl{bottom:.4rem;left:.4rem;transform:scaleY(-1)}.hud-bracket.br{bottom:.4rem;right:.4rem;transform:scale(-1)}

.theme-toggle{display:flex;gap:2px;background:rgba(168,85,247,0.15);border:1px solid rgba(168,85,247,0.2);border-radius:20px;padding:3px;}
.tbtn{width:26px;height:22px;border-radius:14px;border:none;background:transparent;cursor:none;font-size:11px;color:var(--text2);transition:background 0.15s,color 0.15s;}
.tbtn.active{background:var(--bg);color:var(--text);box-shadow:0 1px 4px rgba(0,0,0,0.3);}

#transmission{position:fixed;bottom:3rem;right:1.5rem;z-index:100;background:var(--card);border:1px solid var(--cyan);padding:1rem 1.2rem;max-width:280px;font-family:var(--mono);transform:translateX(120%);transition:transform 0.4s cubic-bezier(0.16,1,0.3,1);box-shadow:0 0 30px rgba(6,182,212,0.15);backdrop-filter:blur(12px);}
#transmission.show{transform:translateX(0)}
