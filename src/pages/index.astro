---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date) {
  return new Date(date).toLocaleDateString('en-IN', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>harshtakes.lol — Harsh Mudgal</title>
  <meta name="description" content="Tech, law, AI. By Harshvardhan Mudgal." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #020408;
      --purple: #a855f7;
      --cyan: #06b6d4;
      --green: #10b981;
      --pink: #ec4899;
      --amber: #f59e0b;
      --text: #e2e8f0;
      --text2: #475569;
      --mono: 'Share Tech Mono', monospace;
      --orb: 'Orbitron', sans-serif;
      --sans: 'Outfit', sans-serif;
    }
    html, body { background: var(--bg); color: var(--text); font-family: var(--sans); min-height: 100vh; overflow-x: hidden; cursor: none; -webkit-font-smoothing: antialiased; }

    /* ── THREE.JS CANVAS ── */
    #three-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.7; }

    /* ── 2D CANVAS LAYERS ── */
    #trail-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; pointer-events: none; }
    #particle-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; }

    /* ── OVERLAYS ── */
    .scanlines { position: fixed; inset: 0; z-index: 3; pointer-events: none; background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.07) 3px, rgba(0,0,0,0.07) 4px); }
    .grid-overlay { position: fixed; inset: 0; z-index: 3; pointer-events: none; background-image: linear-gradient(rgba(6,182,212,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(6,182,212,0.03) 1px, transparent 1px); background-size: 55px 55px; }

    /* ── CURSOR ── */
    #cursor { position: fixed; pointer-events: none; z-index: 9999; transform: translate(-50%, -50%); transition: transform 0.05s; }
    #cursor-outer { width: 28px; height: 28px; border: 1px solid rgba(6,182,212,0.6); border-radius: 50%; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); animation: cur-pulse 2s ease-in-out infinite; }
    #cursor-inner { width: 5px; height: 5px; background: var(--cyan); border-radius: 50%; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); box-shadow: 0 0 8px var(--cyan); }
    #cursor-h { position: absolute; top: 50%; left: -8px; right: -8px; height: 1px; background: rgba(6,182,212,0.5); transform: translateY(-50%); }
    #cursor-v { position: absolute; left: 50%; top: -8px; bottom: -8px; width: 1px; background: rgba(6,182,212,0.5); transform: translateX(-50%); }
    @keyframes cur-pulse { 0%,100%{transform:translate(-50%,-50%) scale(1);opacity:0.8} 50%{transform:translate(-50%,-50%) scale(1.5);opacity:0.3} }

    /* ── HUD ── */
    .hud { position: fixed; z-index: 10; font-family: var(--mono); font-size: 0.58rem; color: var(--cyan); pointer-events: none; line-height: 2; letter-spacing: 0.07em; opacity: 0.65; }
    .hud-tl { top: 1rem; left: 1rem; }
    .hud-tr { top: 1rem; right: 1rem; text-align: right; }
    .hud-bl { bottom: 1rem; left: 1rem; }
    .hud-br { bottom: 1rem; right: 1rem; text-align: right; }
    .hv { color: var(--purple); }
    .hg { color: var(--green); }
    .hud-bar { display: inline-block; width: 50px; height: 3px; background: rgba(168,85,247,0.2); vertical-align: middle; margin-left: 4px; position: relative; }
    .hud-bar-fill { height: 100%; background: linear-gradient(90deg, var(--purple), var(--cyan)); transition: width 1.5s ease; }
    .hud-bracket { position: fixed; z-index: 10; pointer-events: none; opacity: 0.35; }
    .hud-bracket.tl { top: 0.4rem; left: 0.4rem; }
    .hud-bracket.tr { top: 0.4rem; right: 0.4rem; transform: scaleX(-1); }
    .hud-bracket.bl { bottom: 0.4rem; left: 0.4rem; transform: scaleY(-1); }
    .hud-bracket.br { bottom: 0.4rem; right: 0.4rem; transform: scale(-1); }

    /* ── INTERCEPTED TRANSMISSION ── */
    #transmission {
      position: fixed; bottom: 3rem; right: 1.5rem; z-index: 100;
      background: rgba(2, 4, 8, 0.95); border: 1px solid var(--cyan);
      padding: 1rem 1.2rem; max-width: 280px; font-family: var(--mono);
      transform: translateX(120%); transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
      box-shadow: 0 0 30px rgba(6,182,212,0.2), inset 0 0 30px rgba(6,182,212,0.03);
    }
    #transmission.show { transform: translateX(0); }
    #transmission::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--cyan), transparent); }
    .tx-label { font-size: 0.55rem; letter-spacing: 0.15em; color: var(--green); margin-bottom: 0.4rem; text-transform: uppercase; }
    .tx-text { font-size: 0.68rem; color: var(--text); line-height: 1.6; }
    .tx-close { position: absolute; top: 0.5rem; right: 0.6rem; font-size: 0.6rem; color: var(--text2); cursor: none; }

    /* ── MAIN PAGE ── */
    .page { position: relative; z-index: 5; max-width: 820px; margin: 0 auto; padding: 0 2rem 8rem; }

    /* ── HEADER ── */
    .site-header { display: flex; justify-content: space-between; align-items: center; padding: 2rem 0 1.5rem; border-bottom: 1px solid rgba(6,182,212,0.12); }
    .logo { font-family: var(--orb); font-size: 0.82rem; font-weight: 900; color: var(--text); text-decoration: none; letter-spacing: 0.12em; text-transform: uppercase; }
    .logo .lc { color: var(--cyan); text-shadow: 0 0 20px rgba(6,182,212,0.5); }
    .logo .lp { color: var(--purple); }
    .nav { display: flex; align-items: center; gap: 2rem; }
    .nav a { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text2); text-decoration: none; position: relative; transition: color 0.2s; }
    .nav a::after { content: ''; position: absolute; bottom: -2px; left: 0; right: 0; height: 1px; background: var(--cyan); transform: scaleX(0); transition: transform 0.25s; transform-origin: left; }
    .nav a:hover { color: var(--cyan); }
    .nav a:hover::after { transform: scaleX(1); }
    .sig { display: flex; align-items: center; gap: 0.45rem; font-family: var(--mono); font-size: 0.58rem; color: var(--green); letter-spacing: 0.12em; }
    .sig-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px var(--green), 0 0 16px rgba(16,185,129,0.4); animation: sig 2s ease-in-out infinite; }
    @keyframes sig { 0%,100%{opacity:1}50%{opacity:0.25} }

    /* ── HERO ── */
    .hero { padding: 5rem 0 3rem; }
    .hero-eye { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.2em; color: var(--green); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.8rem; text-transform: uppercase; }
    .hero-eye::before { content: ''; display: block; width: 28px; height: 1px; background: var(--green); box-shadow: 0 0 8px var(--green); }
    .hero-eye::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, rgba(16,185,129,0.3), transparent); }

    .title-wrap { margin-bottom: 0.6rem; }
    .t-line1 { display: block; font-family: var(--orb); font-size: clamp(1.8rem, 5vw, 3.6rem); font-weight: 900; color: var(--text); letter-spacing: -0.01em; line-height: 1.05; }
    .t-line2 { display: block; font-family: var(--orb); font-size: clamp(1.8rem, 5vw, 3.6rem); font-weight: 900; letter-spacing: -0.01em; line-height: 1.05; background: linear-gradient(90deg, var(--purple), var(--cyan), var(--pink), var(--purple)); background-size: 300% 100%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: shimmer 4s linear infinite; }
    @keyframes shimmer { 0%{background-position:0% 50%}100%{background-position:300% 50%} }

    .lang-label { font-family: var(--mono); font-size: 0.6rem; color: var(--purple); letter-spacing: 0.1em; margin-bottom: 0.4rem; opacity: 0.7; }
    .hero-sub { font-family: var(--mono); font-size: 0.7rem; color: var(--purple); letter-spacing: 0.06em; margin-bottom: 1.8rem; opacity: 0.8; }
    .hero-bio { font-size: 0.95rem; color: var(--text2); max-width: 480px; line-height: 1.85; margin-bottom: 2rem; }

    /* ── TAGS ── */
    .tag-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .tag { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.35em 1em; border-radius: 1px; position: relative; overflow: hidden; transition: all 0.25s; cursor: none; }
    .tag::before { content: ''; position: absolute; inset: 0; transform: translateX(-101%); transition: transform 0.3s ease; }
    .tag:hover::before { transform: translateX(0); }
    .tag:hover { transform: translateY(-2px); }
    .tp { border: 1px solid rgba(168,85,247,0.35); color: var(--purple); background: rgba(168,85,247,0.07); }
    .tp::before { background: rgba(168,85,247,0.18); }
    .tc { border: 1px solid rgba(6,182,212,0.35); color: var(--cyan); background: rgba(6,182,212,0.07); }
    .tc::before { background: rgba(6,182,212,0.18); }
    .tg { border: 1px solid rgba(16,185,129,0.35); color: var(--green); background: rgba(16,185,129,0.07); }
    .tg::before { background: rgba(16,185,129,0.18); }

    /* ── DIVIDER ── */
    .divider { display: flex; align-items: center; gap: 1rem; margin: 2.5rem 0 1.5rem; }
    .div-label { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text2); white-space: nowrap; }
    .div-line { flex: 1; height: 1px; background: linear-gradient(90deg, rgba(168,85,247,0.4), transparent); }
    .div-count { font-family: var(--mono); font-size: 0.58rem; color: var(--purple); white-space: nowrap; }

    /* ── POST CARDS ── */
    .post-list { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
    .post-card {
      position: relative; border: 1px solid rgba(168,85,247,0.12);
      background: rgba(8,8,18,0.7); backdrop-filter: blur(12px);
      padding: 1.4rem 1.6rem; cursor: none; overflow: hidden;
      transition: border-color 0.3s;
      transform-style: preserve-3d;
      transform: perspective(800px) rotateX(0deg) rotateY(0deg);
    }
    .post-card:hover { border-color: rgba(6,182,212,0.35); }
    .post-card::before {
      content: ''; position: absolute; top: 0; left: -100%; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--cyan), transparent);
      transition: left 0.6s ease;
    }
    .post-card:hover::before { left: 100%; }
    .post-card::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(168,85,247,0.03), rgba(6,182,212,0.03));
      opacity: 0; transition: opacity 0.3s;
    }
    .post-card:hover::after { opacity: 1; }

    .card-glow { position: absolute; inset: 0; background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(6,182,212,0.06), transparent 60%); pointer-events: none; opacity: 0; transition: opacity 0.3s; }
    .post-card:hover .card-glow { opacity: 1; }

    .card-inner { display: grid; grid-template-columns: 1fr auto; gap: 1rem; align-items: start; position: relative; z-index: 1; }
    .card-inner a { text-decoration: none; color: inherit; }
    .card-idx { font-family: var(--mono); font-size: 0.52rem; color: rgba(168,85,247,0.35); letter-spacing: 0.12em; margin-bottom: 0.35rem; }
    .post-title { font-family: var(--sans); font-size: 1rem; font-weight: 500; color: var(--text); line-height: 1.3; margin-bottom: 0.4rem; display: block; transition: color 0.2s; }
    .post-card:hover .post-title { color: var(--cyan); }
    .post-desc { font-family: var(--mono); font-size: 0.7rem; color: var(--text2); line-height: 1.5; }
    .post-date { font-family: var(--mono); font-size: 0.6rem; color: var(--purple); white-space: nowrap; padding-top: 0.2rem; letter-spacing: 0.04em; }
    .card-corner { position: absolute; bottom: 0.6rem; right: 0.8rem; font-family: var(--mono); font-size: 0.5rem; color: rgba(6,182,212,0.2); letter-spacing: 0.08em; z-index: 1; transition: color 0.2s; }
    .post-card:hover .card-corner { color: rgba(6,182,212,0.5); }

    /* ── FOOTER ── */
    .site-footer { margin-top: 5rem; padding: 1.5rem 0; border-top: 1px solid rgba(6,182,212,0.08); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    .footer-text { font-family: var(--mono); font-size: 0.58rem; color: var(--text2); letter-spacing: 0.1em; text-transform: uppercase; }
    .footer-text span { color: var(--cyan); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp { from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)} }
    .hero { animation: fadeUp 0.7s 0.2s ease both; }
    .site-header { animation: fadeUp 0.5s 0.1s ease both; }
    .post-card { animation: fadeUp 0.5s ease both; }
    .post-card:nth-child(1){animation-delay:0.3s}
    .post-card:nth-child(2){animation-delay:0.38s}
    .post-card:nth-child(3){animation-delay:0.46s}
    .post-card:nth-child(4){animation-delay:0.54s}
    .post-card:nth-child(5){animation-delay:0.62s}

    @media(max-width:560px){
      .t-line1,.t-line2{font-size:1.7rem}
      .card-inner{grid-template-columns:1fr}
      .hud-tr,.hud-br{display:none}
    }
  </style>
</head>
<body>

  <!-- Cursor -->
