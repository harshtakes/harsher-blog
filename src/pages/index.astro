    <section class="hero">
      <div class="hero-eye">neural signal active — delhi, india — 2026</div>
      <div class="lang-label" id="lang-label">[ EN ]</div>
      <div class="title-wrap">
        <span class="t-line1" id="title-1">LAW MEETS MACHINE.</span>
        <span class="t-line2" id="title-2">HARSH TAKES ONLY.</span>
