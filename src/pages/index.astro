@media(max-width:900px){.page{padding:0 2rem 8rem;}}
@media(max-width:560px){.t-line1,.t-line2{font-size:1.6rem}.card-inner{grid-template-columns:1fr}.hud-tr,.hud-br{display:none}.page{padding:0 1.25rem 6rem;}}
</style>
